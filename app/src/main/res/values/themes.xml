<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Murexide" parent="android:Theme.Material.Light.NoActionBar">
        <item name="colorSurface">@android:color/white</item>
        <item name="isLightTheme">true</item>
    </style>

    <style name="Theme.App.Starting" parent="Theme.Murexide">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:statusBarColor">?attr/colorSurface</item>
        <item name="android:navigationBarColor">?attr/colorSurface</item>
        <item name="android:windowLightStatusBar">?attr/isLightTheme</item>
    </style>

    <!-- OpenImage's default theme displays a position indicator and uses an
         edge-to-edge window.  Keep the viewer on a black canvas, hide the
         indicator, and leave system-bar space around the image. -->
    <style name="Theme.Murexide.OpenImage" parent="Theme.OpenImageTheme">
        <item name="openImage.indicator.type">none</item>
        <item name="openImage.statusBar.fontStyle">dark</item>
        <item name="openImage.background">@android:color/black</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:statusBarColor">@android:color/black</item>
        <item name="android:navigationBarColor">@android:color/black</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
